# Django admin settings
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Shared PostgreSQL (same database as the FastAPI backend)
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_dev_password
POSTGRES_DB=opportunity_nexus
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional: auto-create a superuser on first boot (used by docker-entrypoint.sh)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@opportunity-nexus.local
DJANGO_SUPERUSER_PASSWORD=admin_dev_password
