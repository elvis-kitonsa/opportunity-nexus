# Root environment for docker-compose. Copy to `.env` and adjust before running.

# --- PostgreSQL (shared by FastAPI and Django) ---
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_dev_password
POSTGRES_DB=opportunity_nexus

# --- FastAPI backend ---
SECRET_KEY=change-me-to-a-long-random-string
BACKEND_CORS_ORIGINS=http://localhost:5173
VERIFIED_INSTITUTION_DOMAINS=mak.ac.ug,kyu.ac.ug,mubs.ac.ug

# --- Django admin ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@opportunity-nexus.local
DJANGO_SUPERUSER_PASSWORD=admin_dev_password
